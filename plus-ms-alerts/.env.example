PORT=3002
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/api-alertas
MONGODB_RETRIES=5
MONGODB_RETRY_DELAY_MS=2000

CORS_ORIGIN=http://localhost:3000,http://localhost:4001

# Use the same secret/public key used by the auth backend to sign tokens.
# For HS256/local development, keep JWT_PUBLIC_KEY empty and use JWT_SECRET.
# Deve ser igual ao JWT_SECRET do microservico de autenticacao.
JWT_SECRET=change-me-in-production
JWT_PUBLIC_KEY=
JWT_ALGORITHMS=HS256
JWT_ISSUER=
JWT_AUDIENCE=

# Comma-separated roles allowed to manage alerts.
ADMIN_ROLES=ADMIN,ADM
