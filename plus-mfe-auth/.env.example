# URL do microservico responsavel por login/cadastro/autenticacao.
# Nao aponte esta variavel para o plus-ms-alerts, porque alerts nao faz login.
VITE_MS_AUTH_URL=http://localhost:3001

# Caso este MFE tambem consuma alertas diretamente no futuro,
# use uma variavel separada para manter os microservicos desacoplados.
VITE_MS_ALERTS_URL=http://localhost:3002
