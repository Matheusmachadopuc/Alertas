# Ports
SHELL_PORT=3000
MS_AUTH_PORT=3001
MS_ALERTS_PORT=3002
MFE_AUTH_PORT=4001

# Auth
# Must be shared by the auth backend and plus-ms-alerts so alerts can validate tokens.
JWT_SECRET=change-me-in-production

# AWS / Ministack
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566

# RDS/PostgreSQL used by the auth service
DB_HOST=localhost
DB_PORT=5432
DB_USER=chave
DB_PASSWORD=chave_secret
DB_NAME=chave_auth

# MongoDB used by plus-ms-alerts
MONGO_ALERTS_PORT=27017
MONGO_ALERTS_DATABASE=api-alertas

# Roles allowed to manage alerts
ALERTS_ADMIN_ROLES=ADMIN,ADM,admin
